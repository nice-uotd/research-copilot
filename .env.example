# ============================================================
# Research Copilot - 环境变量模板（公开版）
# 复制为 .env 并填入真实值；.env 已在 .gitignore 中不会被提交
# ============================================================

# ---------- 应用 ----------
APP_NAME=research-copilot
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# ---------- LLM（OpenAI 兼容协议；推荐阿里百炼免费额度）----------
# 阿里百炼: https://bailian.console.aliyun.com/   (DeepSeek-V3 + text-embedding-v3 免费 100万 token)
# 也可换成 OpenAI / Moonshot / 智谱 / SiliconFlow，只要兼容 OpenAI 协议
OPENAI_API_KEY=sk-your-key-here
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=deepseek-v3
EMBEDDING_MODEL=text-embedding-v3

# ---------- 数据库（默认 SQLite，无需 Docker）----------
DATABASE_URL=sqlite+aiosqlite:///./data/agent.db

# ---------- Redis（可选，记忆模块未启用时不需要） ----------
REDIS_URL=redis://localhost:6379/0

# ---------- 向量库 collection 名 ----------
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_COLLECTION_NAME=agent_knowledge

# ---------- Cross-Encoder 重排（首次启用会下载 ~280MB） ----------
RERANK_MODEL=BAAI/bge-reranker-base
RERANK_ENABLED=true
RETRIEVE_OVERSAMPLE=4

# ---------- LLM-as-judge 终排（默认关；按请求 use_llm_judge=true 启用） ----------
LLM_JUDGE_ENABLED=false

# ---------- HuggingFace 国内镜像（拉模型用） ----------
HF_ENDPOINT=https://hf-mirror.com

# ---------- Web Search（Tavily 可选，没填则自动回退 DDGS） ----------
# 注册免费 1000 次/月: https://app.tavily.com
TAVILY_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT=15

# ---------- 日志 ----------
LOG_LEVEL=INFO
